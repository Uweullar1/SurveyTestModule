{
    "version": 2,
    "functions": {
        "api/supabase-proxy.js": {
            "memory": 128,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/supabase-proxy",
            "destination": "/api/supabase-proxy"
        },
        {
            "source": "/api/supabase-proxy/(.*)",
            "destination": "/api/supabase-proxy?path=$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}