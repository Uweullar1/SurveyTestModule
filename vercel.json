{
    "version": 2,
    "buildCommand": "cd opros-module && npm install && npm run build",
    "outputDirectory": "opros-module/dist",
    "rewrites": [
        {
            "source": "/api/supabase-proxy/(.*)",
            "destination": "/api/supabase-proxy?path=$1"
        },
        {
            "source": "/api/supabase-proxy",
            "destination": "/api/supabase-proxy"
        },
        {
            "source": "/(.*)",
            "destination": "/opros-module/dist/index.html"
        }
    ]
}