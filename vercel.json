{
    "version": 2,
    "functions": {
        "opros-modul/api/supabase-proxy.js": {
            "runtime": "vercel-nodejs@20"
        }
    },
    "rewrites": [
        {
            "source": "/api/supabase-proxy/(.*)",
            "destination": "/opros-modul/api/supabase-proxy.js"
        },
        {
            "source": "/(.*)",
            "destination": "/opros-modul/dist/index.html"
        }
    ]
}