{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/supabase-proxy",
            "destination": "/api/supabase-proxy"
        },
        {
            "source": "/api/supabase-proxy/:path*",
            "destination": "/api/supabase-proxy?path=:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}